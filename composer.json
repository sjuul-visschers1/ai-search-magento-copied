{
    "name": "springbok/module-ai-search",
    "description": "Magento 2 integration for Site Search AI.",
    "type": "magento2-module",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.2",
        "magento/framework": "^103.0.6",
        "magento/module-store": "^101.1.6",
        "magento/module-config": "^101.2.6",
        "magento/module-customer": "^103.0.6",
        "magento/module-catalog-search": "^102.0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "files": ["registration.php"],
        "psr-4": {
            "Springbok\\SiteSearchAi\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Springbok\\SiteSearchAi\\Test\\": "Test/"
        }
    }
}
